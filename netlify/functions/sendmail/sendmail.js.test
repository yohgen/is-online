exports.handler = (event) => {
  let data = event.body;

  console.log(data.email);
  console.log(data.msg);

  let x = () => {
    let prom = new Promise((res, rej) => {
      let response = {
        statusCode: 200,
        body: JSON.stringify({
          result: 'failure',
        }),
      };

      setTimeout(() => res(response), 3000);
    });

    return prom;
  };
  
  return x()
    .then((res) => {
      return res;
    })
};